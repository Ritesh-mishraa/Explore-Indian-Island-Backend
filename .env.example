PORT=5001

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_key
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:5173

# Gmail OAuth2 (used for sending emails — forgotPassword / OTP)
EMAIL=your_gmail@gmail.com
OAUTH_CLIENT_ID=your_google_oauth_client_id
OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token

# Email display name
FROM_NAME=ExploreIndianIslands

# Optional external APIs
WEATHER_API_KEY=your_weather_api_key
